---
layout: layouts/base.njk
title: Blog
---
<div class="container">
    <nav class="post-nav">
        <a href="/">&larr; Home</a>
    </nav>
    <h1>Blog</h1>
    <ul class="blog-list">
        {%- for post in collections.posts | reverse %}
        <li>
            <a href="{{ post.url }}">{{ post.data.title }}</a>
            <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
        </li>
        {%- endfor %}
    </ul>
</div>
